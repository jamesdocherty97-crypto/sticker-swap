+/* ── PWA INSTALL ── */
+let _installEvt=null;
+window.addEventListener('beforeinstallprompt',e=>{e.preventDefault();_installEvt=e;if(me&&curTab==='group')renderGroup();});
+window.addEventListener('appinstalled',()=>{_installEvt=null;toast('Sticker Swap installed 📲');if(me&&curTab==='group')renderGroup();});
+function isStandalone(){return window.matchMedia?.('(display-mode: standalone)')?.matches||navigator.standalone===true;}
+function isIOS(){return/iphone|ipad|ipod/i.test(navigator.userAgent||'');}
+window.installApp=async function(){
+  if(!_installEvt)return toast('Use your browser menu to install');
+  const e=_installEvt;_installEvt=null;
+  e.prompt();
+  const r=await e.userChoice.catch(()=>null);
+  if(!(r&&r.outcome==='accepted'))_installEvt=e;
+  if(me&&curTab==='group')renderGroup();
+};
+function installHTML(){
+  if(isStandalone())return'';
+  if(_installEvt)return`<div class="share-row"><button class="share-btn" onclick="installApp()">📲 Install the app</button></div>`;
+  if(isIOS())return`<div class="settings-copy" style="margin-bottom:0">📲 Install: tap Share, then "Add to Home Screen".</div>`;
+  return'';
+}
