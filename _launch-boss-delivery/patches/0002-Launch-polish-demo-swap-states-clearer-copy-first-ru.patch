+// Seed the full swap lifecycle so the demo shows an incoming offer, an
+// outgoing offer, and an accepted swap where the other side already
+// confirmed the handover. Uses the actual demo collections, so every id
+// is consistent and promised spares are genuinely reserved.
+function demoTradeSlice(a,b,n){
+  const give=[],get=[];
+  for(const id of swapIds()){
+    if(give.length<n&&availableSparesFor(a,id)>0&&activeNeed(b,id))give.push(id);
+    else if(get.length<n&&availableSparesFor(b,id)>0&&activeNeed(a,id))get.push(id);
+    if(give.length>=n&&get.length>=n)break;
+  }
+  return{give,get};
+}
+function seedDemoSwaps(){
+  try{
+    const now=Date.now();
+    const mk=(id,from,to,t,extra)=>({id,from,to,fromUid:from,toUid:to,fromName:from,toName:to,give:t.give,get:t.get,status:'proposed',createdAt:now-3600e3,updatedAt:now-3600e3,ts:now-3600e3,...extra});
+    const t1=demoTradeSlice('Sam','You',2);   // incoming offer for You
+    if(t1.give.length||t1.get.length)swapItems.push(mk('demo-seed-in','Sam','You',t1));
+    const t2=demoTradeSlice('You','Ava',2);   // outgoing offer from You
+    if(t2.give.length||t2.get.length)swapItems.push(mk('demo-seed-out','You','Ava',t2));
+    const t3=demoTradeSlice('Mo','You',1);    // accepted - Mo already confirmed his side
+    if(t3.give.length||t3.get.length)swapItems.push(mk('demo-seed-half','Mo','You',t3,{status:'accepted',acceptedTs:now-1800e3,fromDone:true,updatedAt:now-900e3}));
+    persistDemo();
+  }catch(e){}
+}
 
