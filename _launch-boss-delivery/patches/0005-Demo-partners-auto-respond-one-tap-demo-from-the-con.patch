+// Demo partners respond on their own, so one device can experience the whole
+// loop: send offer → friend accepts → both confirm → books update.
+function demoAutoAccept(id,ms){
+  if(!DEMO_MODE)return;
+  setTimeout(()=>{
+    const p=swapItems.find(x=>x.id===id);
+    if(!p||p.status!=='proposed'||p.from!==me)return;
+    Object.assign(p,{status:'accepted',acceptedTs:Date.now(),updatedAt:Date.now()});
+    persistDemo();
+    queuePop({kicker:'Offer accepted',title:`${displayName(p.to)} said yes!`,sub:'Swap in person, then confirm',bg:'assets/10_incoming_offer_art.webp'});
+    toast(`${displayName(p.to)} accepted - swap in person, then confirm`);
+    updateBadge();if(curTab==='swaps')renderSwaps();
+  },ms||7000);
+}
+function demoPartnerConfirm(id,ms){
+  if(!DEMO_MODE)return;
+  setTimeout(()=>{
+    const p=swapItems.find(x=>x.id===id);
+    if(!p||p.status!=='accepted'||(p.from!==me&&p.to!==me))return;
+    const otherField=p.from===me?'toDone':'fromDone';
+    if(p[otherField])return;
+    p[otherField]=true;p.updatedAt=Date.now();
+    if(myDoneFor(p))p.status='done';
+    persistDemo();
+    if(p.status==='done')applyCompletedSwapToMine(p);
+    else toast(`${displayName(otherFor(p))} confirmed - your confirmation finishes the swap`);
+    if(curTab==='swaps')renderSwaps();
+  },ms||6000);
+}
